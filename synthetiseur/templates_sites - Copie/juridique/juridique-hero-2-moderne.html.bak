<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{NOM_ENTREPRISE}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --color-accent: #2d6a4f;
  --color-accent-light: #2d6a4f;
  --color-gold: #c9a84c;
  --color-bg-dark: #05152e;
  --color-text: #ffffff;
  --color-text-muted: rgba(255,255,255,.70);
  --color-text-muted-2: rgba(255,255,255,.45);
  --color-border: rgba(255,255,255,.08);
  --color-border-light: rgba(255,255,255,.06);
  --color-card-bg: rgba(255,255,255,.06);
  --ff-heading: 'Libre Baskerville', serif;
  --ff-serif: 'EB Garamond', serif;
  --ff-body: 'Inter', sans-serif;
  --fs-title: clamp(1.8rem, 7vw, 2.5rem);
  --fs-subtitle: 0.9375rem;
  --fs-body: 0.875rem;
  --fs-small: 0.75rem;
  --fs-tiny: 0.68rem;
  --fs-nav: 0.7rem;
  --lh-tight: 1.1;
  --lh-normal: 1.9;
  --nav-height: 4.5rem;
  --container-padding: 1.25rem;
  --radius-sm: 0.125rem;
  --radius-md: 6px;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --duration-fast: 0.2s;
  --duration-medium: 0.35s;
}
@media (min-width: 768px) {
  :root {
    --fs-title: clamp(2.2rem, 5vw, 3.5rem);
    --fs-body: 0.9375rem;
    --container-padding: 2rem;
    --nav-height: 5rem;
  }
}
@media (min-width: 1024px) {
  :root {
    --fs-body: 1rem;
    --container-padding: 2.5rem;
    --nav-height: 5.5rem;
  }
}
*,
*::before,
*::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: var(--ff-body); font-size: var(--fs-body); font-weight: 400;
  line-height: var(--lh-normal); color: var(--color-text);
  background: var(--color-bg-dark); overflow-x: hidden;
  -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
}
img { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; }
ul { list-style: none; }
button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
:focus-visible { outline: 2px solid var(--color-accent-light); outline-offset: 2px; }
.icon { width: 1em; height: 1em; fill: none; stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
.icon--md { width: 1.25em; height: 1.25em; }
.sr-only { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0,0,0,0); border: 0; }

.hero { position: relative; display: flex; flex-direction: column; overflow: hidden; }
.hero-bg {
  position: absolute; inset: 0;
  background: url('https://images.unsplash.com/photo-1559526324-593bc073d938?w=1600&q=90') center / cover no-repeat;
}
.hero-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(to top, rgba(5,15,30,.97) 0%, rgba(5,15,30,.88) 35%, rgba(5,15,30,.60) 58%, rgba(5,15,30,.25) 78%, transparent 100%),
    linear-gradient(to right, rgba(5,15,30,.5) 0%, transparent 55%);
}

.nav { position: relative; z-index: 10; display: flex; align-items: center; justify-content: space-between; height: var(--nav-height); padding-inline: var(--container-padding); flex-shrink: 0; border-bottom: 1px solid var(--color-border); }
.nav-desktop { display: none; align-items: center; justify-content: space-between; width: 100%; }
.nav-logo-img { height: 34px; max-width: 150px; width: auto; object-fit: contain; filter: brightness(0) invert(1); display: none; }
.nav-logo-text { font-family: var(--ff-serif); font-size: 1.25rem; font-weight: 500; color: var(--color-text); letter-spacing: .03em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
.nav-logo-text span { color: var(--color-accent); }
.nav-links { display: flex; gap: 2rem; }
.nav-links a { font-size: var(--fs-nav); font-weight: 500; letter-spacing: .14em; text-transform: uppercase; color: var(--color-text-muted); transition: color var(--duration-fast); }
.nav-links a:hover { color: var(--color-accent); }
.nav-mobile { display: flex; align-items: center; justify-content: space-between; width: 100%; gap: .75rem; }
.nav-mobile-tel { font-size: var(--fs-tiny); font-weight: 400; letter-spacing: .08em; color: var(--color-text-muted); white-space: nowrap; transition: color var(--duration-fast); display: flex; align-items: center; gap: .375rem; }
.nav-mobile-tel:hover { color: var(--color-text); }
.nav-mobile-logo { flex: 1; }

.nav-cta { display: none; align-items: center; gap: .5rem; padding: .5rem 1.25rem; background: var(--color-gold); font-size: var(--fs-nav); font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--color-bg-dark); border-radius: var(--radius-sm); transition: background var(--duration-fast), color var(--duration-fast); white-space: nowrap; }
.nav-cta:hover { background: var(--color-text); color: var(--color-bg-dark); }
.hamburger { position: relative; z-index: 110; display: flex; flex-direction: column; justify-content: space-between; width: 1.5rem; height: 1rem; padding: 0; flex-shrink: 0; }
.hamburger-line { display: block; width: 100%; height: 1.5px; background: var(--color-text); border-radius: 1px; transition: transform var(--duration-medium) var(--ease-out), opacity var(--duration-medium) var(--ease-out); transform-origin: center; }
.hamburger--active .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger--active .hamburger-line:nth-child(2) { opacity: 0; }
.hamburger--active .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
.mobile-menu {
  position: fixed; inset: 0; z-index: 105; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 2rem;
  background: rgba(12,12,14,.98); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  opacity: 0; visibility: hidden; transition: opacity var(--duration-medium) var(--ease-out), visibility var(--duration-medium) var(--ease-out);
}
.mobile-menu--open { opacity: 1; visibility: visible; }
.mobile-menu-close { position: absolute; top: 1rem; right: 1rem; width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center; z-index: 115; }
.mobile-menu-close svg { width: 1.25rem; height: 1.25rem; stroke: var(--color-text); stroke-width: 2; }
.mobile-menu-list { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
.mobile-menu-list a { font-size: .85rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.8); transition: color var(--duration-fast); }
.mobile-menu-list a:hover { color: var(--color-text); }
.mobile-menu-cta { display: inline-flex; align-items: center; gap: .5rem; padding: .75rem 2rem; border: 1px solid rgba(255,255,255,.3); border-radius: 3px; font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.8); transition: background var(--duration-fast), color var(--duration-fast); }
.mobile-menu-cta:hover { background: var(--color-accent); color: var(--color-text); border-color: var(--color-accent); }
body:has(.mobile-menu--open) { overflow: hidden; }

.hero-content { position: relative; z-index: 5; padding: 1.5rem var(--container-padding) 2rem; display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: end; }
.hero-left { max-width: 680px; }
.hero-kicker {
  display: inline-flex; align-items: center; gap: .6rem;
  font-size: var(--fs-tiny); font-weight: 600; letter-spacing: .2em; text-transform: uppercase;
  color: var(--color-gold); margin-bottom: 1.5rem;
  background: rgba(201,168,76,.12); padding: .35rem .875rem; border-radius: var(--radius-sm);
}
.hero-title {
  font-family: var(--ff-heading); font-size: var(--fs-title);
  font-weight: 700; line-height: var(--lh-tight);
  color: var(--color-text); margin-bottom: 1.25rem;
  text-shadow: 0 2px 20px rgba(0,0,0,.5);
}
.hero-title em { font-style: italic; font-weight: 400; color: rgba(255,255,255,.75); display: block; }
.hero-desc {
  font-size: var(--fs-subtitle); font-weight: 300;
  color: var(--color-text-muted); line-height: var(--lh-normal);
  max-width: 500px; margin-bottom: 1.5rem;
  text-shadow: 0 1px 8px rgba(0,0,0,.5);
}
.hero-ctas { display: flex; flex-direction: column; align-items: flex-start; gap: .75rem; }

.btn-main {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .875rem 2rem; background: var(--color-accent); color: var(--color-text);
  font-size: .75rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
  border-radius: 3px; box-shadow: 0 4px 16px rgba(45,106,79,.4);
  transition: background var(--duration-fast), color var(--duration-fast), transform var(--duration-fast), box-shadow var(--duration-fast); min-height: 3rem;
}
.btn-main:hover { background: var(--color-text); color: var(--color-bg-dark); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,.3); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .875rem 1.75rem; border: 1.5px solid rgba(255,255,255,.25);
  color: rgba(255,255,255,.82); font-size: .75rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
  border-radius: 3px; transition: border-color var(--duration-fast), color var(--duration-fast); min-height: 3rem;
}
.btn-ghost:hover { border-color: var(--color-text); color: var(--color-text); }

.hero-card { display: none; }
.hero-stats { display: none; }

@media (min-width: 768px) {
  .nav-desktop { display: flex; }
  .nav-mobile { display: none; }
  .nav-cta { display: inline-flex; }
  .hero-content { grid-template-columns: 1fr auto; padding: 2rem var(--container-padding) 3rem; gap: 3rem; }
  .hero-ctas { flex-direction: row; align-items: center; }
  .btn-main { padding: .75rem 2rem; min-height: 2.75rem; }
  .btn-ghost { min-height: 2.75rem; }
  
  
  
}
@media (min-width: 1024px) {
  .hero { min-height: 100svh; }
  .hero-content { padding: 2.5rem var(--container-padding) 4rem; }
  .hero-card {
    display: flex; flex-direction: column; gap: 1.25rem;
    background: var(--color-card-bg); border: 1px solid var(--color-border);
    backdrop-filter: blur(12px); border-radius: var(--radius-md);
    padding: 1.75rem 1.5rem; min-width: 220px;
  }
  .card-item { display: flex; align-items: center; gap: .875rem; }
  .card-icon {
    width: 36px; height: 36px; background: rgba(45,106,79,.2);
    border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .card-strong { display: block; font-size: .82rem; font-weight: 600; color: var(--color-text); }
  .card-small { display: block; font-size: .7rem; color: var(--color-text-muted-2); margin-top: 1px; }
  .card-sep { height: 1px; background: var(--color-border); }
  .hero-stats {
    display: flex; position: absolute; bottom: 0; left: 0; right: 0; z-index: 5;
    border-top: 1px solid var(--color-border);
    background: rgba(5,15,30,.6); backdrop-filter: blur(8px);
  }
  .stat-item { flex: 1; padding: .875rem 2rem; display: flex; align-items: center; justify-content: center; gap: .875rem; border-right: 1px solid var(--color-border-light); }
  .stat-item:last-child { border-right: none; }
  .stat-num { font-family: var(--ff-heading); font-size: 1.6rem; font-weight: 700; color: var(--color-text); line-height: 1; }
  .stat-label { font-size: var(--fs-tiny); font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--color-text-muted-2); }
  
  
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }
  html { scroll-behavior: auto; }
}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
</head>
<body>

<svg style="display:none" aria-hidden="true">
  <symbol id="icon-phone" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></symbol>
  <symbol id="icon-arrow-right" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></symbol>
  <symbol id="icon-star" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></symbol>
  <symbol id="icon-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
</svg>

<section class="hero" aria-label="Présentation">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>

  <nav class="nav" aria-label="Navigation principale">
    <div class="nav-desktop">
      <a href="#" class="nav-logo-text">{{NOM_ENTREPRISE}}<span>.</span></a>
      <ul class="nav-links">
        <li><a href="#">Expertises</a></li>
        <li><a href="#">Le cabinet</a></li>
        <li><a href="#">Tarifs</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
        <a href="#" class="nav-cta">Prendre RDV</a>
        </div>
    <div class="nav-mobile">
      <a href="tel:{{TELEPHONE}}" class="nav-mobile-tel"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>{{TELEPHONE}}</a>
      <a href="#" class="nav-logo-text nav-mobile-logo">{{NOM_ENTREPRISE}}<span>.</span></a>
      <button class="hamburger" aria-label="Menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </nav>

  <div class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu de navigation">
    <button class="mobile-menu-close" aria-label="Fermer le menu">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <ul class="mobile-menu-list">
      <li><a href="#">Expertises</a></li>
      <li><a href="#">Le cabinet</a></li>
      <li><a href="#">Tarifs</a></li>
      <li><a href="#">Contact</a></li>
      <li><a href="#" class="mobile-menu-cta"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>Appeler</a></li>
    </ul>
  </div>

  <div class="hero-content">
    <div class="hero-left">
      <div class="hero-kicker">Cabinet d'Avocats · {{VILLE}}</div>
      <h1 class="hero-title">
        Votre avocat<br>
        <em>de confiance,</em>
        pour défendre vos intérêts.
      </h1>
      <p class="hero-desc">
        Chez {{NOM_ENTREPRISE}}, vos droits sont notre priorité. Une défense sur mesure à {{VILLE}}.
      </p>
      <div class="hero-ctas">
        <a href="#" class="btn-main">Consultation<svg class="icon icon--md" aria-hidden="true"><use href="#icon-arrow-right"/></svg></a>
        <a href="tel:{{TELEPHONE}}" class="btn-ghost"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>{{TELEPHONE}}</a>
      </div>
    </div>

    <div class="hero-card">
      <div class="card-item">
        <div class="card-icon"><svg class="icon" aria-hidden="true"><use href="#icon-star"/></svg></div>
        <div>
          <span class="card-strong">{{NB_AVIS}} avis</span>
          <span class="card-small">Note 4.8/5 Google</span>
        </div>
      </div>
      <div class="card-sep"></div>
      <div class="card-item">
        <div class="card-icon"><svg class="icon" aria-hidden="true"><use href="#icon-shield"/></svg></div>
        <div>
          <span class="card-strong">Confidentialité</span>
          <span class="card-small">Secret professionnel garanti</span>
        </div>
      </div>
      <div class="card-sep"></div>
      <div class="card-item">
        <div class="card-icon"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg></div>
        <div>
          <span class="card-strong">Réponse 24h</span>
          <span class="card-small">{{TELEPHONE}}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-stats">
    <div class="stat-item"><div><div class="stat-num">{{NB_AVIS}}+</div><div class="stat-label">Clients accompagnés</div></div></div>
    <div class="stat-item"><div><div class="stat-num">4.8</div><div class="stat-label">Note Google</div></div></div>
    <div class="stat-item"><div><div class="stat-num">1ère</div><div class="stat-label">Consultation offerte</div></div></div>
  </div>
</section>

<script>(function(){var h=document.querySelector('.hamburger'),m=document.querySelector('.mobile-menu');if(!h||!m)return;function t(o){var n=o!==undefined?o:!m.classList.contains('mobile-menu--open');h.classList.toggle('hamburger--active',n);m.classList.toggle('mobile-menu--open',n);h.setAttribute('aria-expanded',n);m.setAttribute('aria-hidden',!n)}h.addEventListener('click',function(){t()});var c=m.querySelector('.mobile-menu-close');if(c)c.addEventListener('click',function(){t(false)});m.querySelectorAll('a').forEach(function(l){l.addEventListener('click',function(){t(false)})});document.addEventListener('keydown',function(e){if(e.key==='Escape'&&m.classList.contains('mobile-menu--open')){t(false);h.focus()}});var mql=window.matchMedia('(min-width: 768px)');mql.addEventListener('change',function(e){if(e.matches&&m.classList.contains('mobile-menu--open'))t(false)})})();</script>
<script>
(function(){var m=window.matchMedia('(prefers-reduced-motion:reduce)');if(m.matches)return;gsap.registerPlugin(ScrollTrigger);var b=document.querySelector('.hero-bg');if(b){gsap.fromTo(b,{scale:1.08},{scale:1,duration:1.5,ease:'power2.out'})}var h=document.querySelector('.hero-content,.hero-inner,.hero-body');if(h){var c=[];for(var i=0;i<h.children.length;i++){c.push(h.children[i])}gsap.fromTo(c,{y:36,opacity:0},{y:0,opacity:1,duration:.65,stagger:.1,ease:'power2.out',delay:.15})}var s=document.querySelectorAll('.hero-stat-num,.stat-num');s.forEach(function(e){var t=e.textContent.trim();if(/^\d+$/.test(t)){var n=parseInt(t,10);if(n>0&&!isNaN(n)){var o={val:0};gsap.to(o,{val:n,duration:2,ease:'power2.out',scrollTrigger:{trigger:e.closest('.hero-stats,.hero-stats-row')||e.parentElement,start:'top 90%',once:true},onUpdate:function(){e.textContent=Math.round(o.val)}})}}})})();
</script>
</body>
</html>
