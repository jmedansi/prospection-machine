<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{NOM_ENTREPRISE}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --color-accent: #1e3a5f;
  --color-accent-light: #1e3a5f;
  --color-gold: #c9a84c;
  --color-bg-dark: #080f1e;
  --color-text: #ffffff;
  --color-text-muted: rgba(255,255,255,.62);
  --color-text-muted-2: rgba(255,255,255,.4);
  --color-border: rgba(255,255,255,.08);
  --color-border-light: rgba(255,255,255,.06);
  --ff-heading: 'EB Garamond', serif;
  --ff-body: 'DM Sans', sans-serif;
  --fs-title: clamp(1.8rem, 7vw, 2.8rem);
  --fs-subtitle: 0.9375rem;
  --fs-body: 0.875rem;
  --fs-small: 0.75rem;
  --fs-tiny: 0.68rem;
  --fs-nav: 0.72rem;
  --lh-tight: 1.1;
  --lh-normal: 1.9;
  --nav-height: 4.5rem;
  --container-padding: 1.25rem;
  --radius-sm: 0.125rem;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --duration-fast: 0.2s;
  --duration-medium: 0.35s;
}
@media (min-width: 768px) {
  :root {
    --fs-title: clamp(2.4rem, 5.5vw, 4.8rem);
    --fs-body: 0.9375rem;
    --container-padding: 2rem;
    --nav-height: 5rem;
  }
}
@media (min-width: 1024px) {
  :root {
    --fs-body: 1rem;
    --container-padding: 2.5rem;
    --nav-height: 5.5rem;
  }
}
*,
*::before,
*::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: var(--ff-body); font-size: var(--fs-body); font-weight: 400;
  line-height: var(--lh-normal); color: var(--color-text);
  background: var(--color-bg-dark); overflow-x: hidden;
  -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
}
img { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; }
ul { list-style: none; }
button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
:focus-visible { outline: 2px solid var(--color-gold); outline-offset: 2px; }
.icon { width: 1em; height: 1em; fill: none; stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
.icon--md { width: 1.25em; height: 1.25em; }
.sr-only { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0,0,0,0); border: 0; }

.hero { position: relative; display: flex; flex-direction: column; justify-content: center; overflow: hidden; }
.hero-bg {
  position: absolute; inset: 0;
  background: url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=1600&q=90') center / cover no-repeat;
  filter: grayscale(30%);
}
.hero-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(to right, rgba(8,15,30,.97) 0%, rgba(8,15,30,.88) 40%, rgba(8,15,30,.55) 65%, rgba(8,15,30,.20) 100%),
    linear-gradient(to top, rgba(8,15,30,.6) 0%, transparent 50%);
}
.hero-line { display: none; }

.nav { position: absolute; top: 0; left: 0; right: 0; z-index: 10; display: flex; align-items: center; justify-content: space-between; height: var(--nav-height); padding-inline: var(--container-padding); border-bottom: 1px solid var(--color-border); }
.nav-logo-img { height: 36px; max-width: 180px; width: auto; object-fit: contain; filter: brightness(0) invert(1); display: none; }
.nav-brand { display: flex; align-items: center; gap: .875rem; }
.nav-brand-text { display: flex; flex-direction: column; max-width: 300px; }
.nav-name { font-family: var(--ff-heading); font-size: 1.25rem; font-weight: 500; color: var(--color-text); letter-spacing: .03em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.nav-name span { color: var(--color-gold); }
.nav-sub { font-size: .6rem; font-weight: 500; letter-spacing: .2em; text-transform: uppercase; color: var(--color-text-muted-2); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.nav-list { display: none; }
.nav-list a { font-size: var(--fs-nav); font-weight: 500; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.55); transition: color var(--duration-fast); }
.nav-list a:hover { color: var(--color-gold); }
.nav-tel { display: none; align-items: center; gap: .5rem; padding: .58rem 1.4rem; border: 1px solid rgba(201,168,76,.4); color: var(--color-gold); font-size: var(--fs-nav); font-weight: 500; letter-spacing: .1em; text-transform: uppercase; border-radius: var(--radius-sm); transition: background var(--duration-fast), color var(--duration-fast), border-color var(--duration-fast); white-space: nowrap; }
.nav-tel:hover { background: var(--color-gold); color: var(--color-bg-dark); border-color: var(--color-gold); }

.hamburger { position: relative; z-index: 110; display: flex; flex-direction: column; justify-content: space-between; width: 1.5rem; height: 1rem; padding: 0; }
.hamburger-line { display: block; width: 100%; height: 1.5px; background: var(--color-text); border-radius: 1px; transition: transform var(--duration-medium) var(--ease-out), opacity var(--duration-medium) var(--ease-out); transform-origin: center; }
.hamburger--active .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger--active .hamburger-line:nth-child(2) { opacity: 0; }
.hamburger--active .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
.mobile-menu {
  position: fixed; inset: 0; z-index: 105; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 2rem;
  background: rgba(8,15,30,.98); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  opacity: 0; visibility: hidden; transition: opacity var(--duration-medium) var(--ease-out), visibility var(--duration-medium) var(--ease-out);
}
.mobile-menu--open { opacity: 1; visibility: visible; }
.mobile-menu-close { position: absolute; top: 1rem; right: 1rem; width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center; z-index: 115; }
.mobile-menu-close svg { width: 1.25rem; height: 1.25rem; stroke: var(--color-text); stroke-width: 2; }
.mobile-menu-list { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
.mobile-menu-list a { font-size: var(--fs-nav); font-weight: 500; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.6); transition: color var(--duration-fast); }
.mobile-menu-list a:hover { color: var(--color-gold); }
.mobile-menu-cta { display: inline-flex; align-items: center; gap: .5rem; padding: .75rem 2rem; border: 1px solid rgba(201,168,76,.4); color: var(--color-gold); font-size: var(--fs-nav); font-weight: 500; letter-spacing: .1em; text-transform: uppercase; border-radius: var(--radius-sm); transition: background var(--duration-fast), color var(--duration-fast), border-color var(--duration-fast); }
.mobile-menu-cta:hover { background: var(--color-gold); color: var(--color-bg-dark); border-color: var(--color-gold); }
.mobile-menu-tel { display: inline-flex; align-items: center; gap: .5rem; font-size: var(--fs-body); font-weight: 400; color: var(--color-text-muted); transition: color var(--duration-fast); }
.mobile-menu-tel:hover { color: var(--color-text); }
.mobile-menu-divider { width: 2rem; height: 1px; background: var(--color-border); }
body:has(.mobile-menu--open) { overflow: hidden; }

.hero-inner { position: relative; z-index: 5; padding: 6rem var(--container-padding) 2rem; max-width: 700px; }
.hero-eyebrow { display: flex; align-items: center; gap: .875rem; margin-bottom: 1.5rem; }
.eyebrow-bar { width: 3px; height: 48px; background: linear-gradient(to bottom, var(--color-accent), var(--color-gold)); flex-shrink: 0; }
.eyebrow-stack { display: flex; flex-direction: column; gap: .3rem; }
.eyebrow-top { font-size: var(--fs-tiny); font-weight: 500; letter-spacing: .22em; text-transform: uppercase; color: var(--color-gold); }
.eyebrow-bot { font-size: var(--fs-tiny); font-weight: 400; letter-spacing: .14em; text-transform: uppercase; color: var(--color-text-muted-2); }

.hero-title {
  font-family: var(--ff-heading); font-size: var(--fs-title);
  font-weight: 500; line-height: var(--lh-tight);
  color: var(--color-text); margin-bottom: 1.25rem;
}
.hero-title em { font-style: italic; color: var(--color-gold); }
.hero-title .block { display: block; }
.hero-divider { display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0; }
.divider-line { flex: 1; height: 1px; background: var(--color-border); max-width: 60px; }
.divider-diamond { width: 6px; height: 6px; background: var(--color-gold); transform: rotate(45deg); flex-shrink: 0; }

.hero-desc {
  font-size: var(--fs-subtitle); font-weight: 300;
  color: var(--color-text-muted); line-height: var(--lh-normal);
  max-width: 480px; margin-bottom: 1.5rem;
}
.hero-specialites { display: flex; gap: .75rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
.spec-tag {
  font-size: var(--fs-tiny); font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
  padding: .35rem .875rem; border: 1px solid rgba(201,168,76,.3);
  color: rgba(255,255,255,.65); border-radius: var(--radius-sm);
}
.hero-ctas { display: flex; flex-direction: column; align-items: flex-start; gap: .75rem; }

.btn-primary {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .875rem 2.25rem; background: var(--color-accent); color: var(--color-text);
  font-size: .75rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
  border-radius: var(--radius-sm); border: 1px solid var(--color-accent);
  transition: background var(--duration-fast), color var(--duration-fast), border-color var(--duration-fast), transform var(--duration-fast), box-shadow var(--duration-fast); min-height: 3rem;
}
.btn-primary:hover { background: var(--color-gold); border-color: var(--color-gold); color: var(--color-bg-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.3); }
.btn-secondary {
  display: inline-flex; align-items: center; gap: .5rem;
  font-size: .82rem; font-weight: 400; color: rgba(255,255,255,.75);
  padding: .5rem 0; transition: color var(--duration-fast); min-height: 3rem;
}
.btn-secondary-underline { border-bottom: 1px solid rgba(255,255,255,.25); padding-bottom: 2px; transition: border-color var(--duration-fast); }
.btn-secondary:hover { color: var(--color-text); }
.btn-secondary:hover .btn-secondary-underline { border-color: var(--color-text); }

.hero-badge { display: none; }
.hero-bottom { display: none; }

@media (min-width: 768px) {
  .nav-list { display: flex; gap: 2.5rem; }
  .nav-tel { display: inline-flex; }
  .hamburger { display: none; }
  .mobile-menu-close { display: none; }
  .hero-inner { padding: 8rem var(--container-padding) 3rem; }
  .hero-ctas { flex-direction: row; align-items: center; }
  .btn-primary { padding: .75rem 2rem; min-height: 2.75rem; }
  .btn-secondary { min-height: 2.75rem; }
  
  
}
@media (min-width: 1024px) {
  .hero { min-height: 100svh; }
  .hero-line {
    display: block; position: absolute; left: 0; top: 0; bottom: 0;
    width: 4px; background: linear-gradient(to bottom, transparent, var(--color-accent), var(--color-gold), transparent);
    z-index: 5;
  }
  .hero-inner { padding: 2rem 3.5rem 8rem 4rem; }
  .hero-badge {
    display: flex; flex-direction: column; gap: 1.25rem;
    position: absolute; right: 3.5rem; bottom: 10rem; z-index: 5;
  }
  .badge-row {
    display: flex; align-items: center; gap: .875rem;
    padding: 1rem 1.25rem; background: rgba(255,255,255,.04);
    border: 1px solid var(--color-border-light); border-left: 3px solid var(--color-gold);
    backdrop-filter: blur(8px); border-radius: var(--radius-sm);
  }
  .badge-text { display: flex; flex-direction: column; }
  .badge-strong { font-size: .8rem; font-weight: 600; color: var(--color-text); }
  .badge-small { font-size: var(--fs-tiny); color: var(--color-text-muted-2); margin-top: 1px; }
  .hero-bottom {
    display: flex; position: absolute; bottom: 0; left: 0; right: 0; z-index: 5;
    border-top: 1px solid var(--color-border);
  }
  .bottom-item { flex: 1; padding: .875rem 2rem; display: flex; align-items: center; gap: .75rem; border-right: 1px solid var(--color-border-light); }
  .bottom-item:last-child { border-right: none; }
  .bottom-strong { display: block; color: rgba(255,255,255,.8); font-size: .78rem; font-weight: 600; }
  .bottom-small { color: var(--color-text-muted-2); font-size: .7rem; }
  
  
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }
  html { scroll-behavior: auto; }
}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
</head>
<body>

<svg style="display:none" aria-hidden="true">
  <symbol id="icon-phone" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></symbol>
  <symbol id="icon-arrow-right" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></symbol>
  <symbol id="icon-map-pin" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></symbol>
  <symbol id="icon-clock" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></symbol>
  <symbol id="icon-star" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></symbol>
  <symbol id="icon-scale" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/><line x1="12" y1="2" x2="12" y2="22"/></symbol>
  <symbol id="icon-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
  <symbol id="icon-file" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></symbol>
</svg>

<section class="hero" aria-label="Présentation">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-line" aria-hidden="true"></div>

  <nav class="nav" aria-label="Navigation principale">
    <div class="nav-brand">
      <img src="{{LOGO_URL}}" class="nav-logo-img" alt="{{NOM_ENTREPRISE}}">
      <div class="nav-brand-text">
        <a href="#" class="nav-name">{{NOM_ENTREPRISE}}<span>.</span></a>
      </div>
    </div>
    <ul class="nav-list">
      <li><a href="#">Expertises</a></li>
      <li><a href="#">Le cabinet</a></li>
      <li><a href="#">Honoraires</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
    <a href="tel:{{TELEPHONE}}" class="nav-tel"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>{{TELEPHONE}}</a>
    <button class="hamburger" aria-label="Menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </nav>

  <div class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu de navigation">
    <button class="mobile-menu-close" aria-label="Fermer le menu">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <ul class="mobile-menu-list">
      <li><a href="#">Expertises</a></li>
      <li><a href="#">Le cabinet</a></li>
      <li><a href="#">Honoraires</a></li>
      <li><a href="#">Contact</a></li>
      <li><a href="#" class="mobile-menu-cta"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>Appeler</a></li>
    </ul>
    <div class="mobile-menu-divider" aria-hidden="true"></div>
    <a href="tel:{{TELEPHONE}}" class="mobile-menu-tel"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>{{TELEPHONE}}</a>
  </div>

  <div class="hero-inner">
    <div class="hero-eyebrow">
      <div class="eyebrow-bar"></div>
      <div class="eyebrow-stack">
        <span class="eyebrow-top">Cabinet d'Avocats · {{VILLE}}</span>
        <span class="eyebrow-bot">Défense &amp; conseil juridique</span>
      </div>
    </div>

    <h1 class="hero-title">
      <span class="block">Votre défense,</span>
      <em>notre engagement</em><span class="block">pour vos droits.</span>
    </h1>

    <div class="hero-divider" aria-hidden="true">
      <div class="divider-line"></div>
      <div class="divider-diamond"></div>
      <div class="divider-line"></div>
    </div>

    <p class="hero-desc">
      {{NOM_ENTREPRISE}} défend vos intérêts avec rigueur à {{VILLE}}. Chaque affaire est unique.
    </p>

    <div class="hero-specialites">
      <span class="spec-tag">Droit des affaires</span>
      <span class="spec-tag">Droit civil</span>
      <span class="spec-tag">Droit de la famille</span>
    </div>

    <div class="hero-ctas">
      <a href="#" class="btn-primary">Consultation<svg class="icon icon--md" aria-hidden="true"><use href="#icon-arrow-right"/></svg></a>
      <a href="tel:{{TELEPHONE}}" class="btn-secondary"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg><span class="btn-secondary-underline">{{TELEPHONE}}</span></a>
    </div>
  </div>

  <div class="hero-badge">
    <div class="badge-row">
      <svg class="icon icon--md" aria-hidden="true"><use href="#icon-star"/></svg>
      <div class="badge-text">
        <span class="badge-strong">{{NB_AVIS}} avis Google</span>
        <span class="badge-small">Note 4.8/5 · Clients satisfaits</span>
      </div>
    </div>
    <div class="badge-row">
      <svg class="icon icon--md" aria-hidden="true"><use href="#icon-shield"/></svg>
      <div class="badge-text">
        <span class="badge-strong">Confidentialité totale</span>
        <span class="badge-small">Secret professionnel garanti</span>
      </div>
    </div>
    <div class="badge-row">
      <svg class="icon icon--md" aria-hidden="true"><use href="#icon-file"/></svg>
      <div class="badge-text">
        <span class="badge-strong">Première consultation offerte</span>
        <span class="badge-small">Sans engagement · 30 minutes</span>
      </div>
    </div>
  </div>

  <div class="hero-bottom">
    <div class="bottom-item">
      <svg class="icon" aria-hidden="true"><use href="#icon-map-pin"/></svg>
      <div>
        <span class="bottom-strong">{{ADRESSE}}</span>
        <span class="bottom-small">{{VILLE}}</span>
      </div>
    </div>
    <div class="bottom-item">
      <svg class="icon" aria-hidden="true"><use href="#icon-clock"/></svg>
      <div>
        <span class="bottom-strong">Lun“Ven 9h“18h</span>
        <span class="bottom-small">Rendez-vous sur demande</span>
      </div>
    </div>
    <div class="bottom-item">
      <svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>
      <div>
        <span class="bottom-strong">{{TELEPHONE}}</span>
        <span class="bottom-small">Réponse sous 24h</span>
      </div>
    </div>
  </div>
</section>

<script>(function(){var h=document.querySelector('.hamburger'),m=document.querySelector('.mobile-menu');if(!h||!m)return;function t(o){var n=o!==undefined?o:!m.classList.contains('mobile-menu--open');h.classList.toggle('hamburger--active',n);m.classList.toggle('mobile-menu--open',n);h.setAttribute('aria-expanded',n);m.setAttribute('aria-hidden',!n)}h.addEventListener('click',function(){t()});var c=m.querySelector('.mobile-menu-close');if(c)c.addEventListener('click',function(){t(false)});m.querySelectorAll('a').forEach(function(l){l.addEventListener('click',function(){t(false)})});document.addEventListener('keydown',function(e){if(e.key==='Escape'&&m.classList.contains('mobile-menu--open')){t(false);h.focus()}});var mql=window.matchMedia('(min-width: 768px)');mql.addEventListener('change',function(e){if(e.matches&&m.classList.contains('mobile-menu--open'))t(false)})})();</script>
<script>
(function(){var m=window.matchMedia('(prefers-reduced-motion:reduce)');if(m.matches)return;gsap.registerPlugin(ScrollTrigger);var b=document.querySelector('.hero-bg');if(b){gsap.fromTo(b,{scale:1.08},{scale:1,duration:1.5,ease:'power2.out'})}var h=document.querySelector('.hero-content,.hero-inner,.hero-body');if(h){var c=[];for(var i=0;i<h.children.length;i++){c.push(h.children[i])}gsap.fromTo(c,{y:36,opacity:0},{y:0,opacity:1,duration:.65,stagger:.1,ease:'power2.out',delay:.15})}var s=document.querySelectorAll('.hero-stat-num,.stat-num');s.forEach(function(e){var t=e.textContent.trim();if(/^\d+$/.test(t)){var n=parseInt(t,10);if(n>0&&!isNaN(n)){var o={val:0};gsap.to(o,{val:n,duration:2,ease:'power2.out',scrollTrigger:{trigger:e.closest('.hero-stats,.hero-stats-row')||e.parentElement,start:'top 90%',once:true},onUpdate:function(){e.textContent=Math.round(o.val)}})}}})})();
</script>
</body>
</html>
