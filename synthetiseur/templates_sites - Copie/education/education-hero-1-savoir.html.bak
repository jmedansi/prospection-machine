<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{NOM_ENTREPRISE}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --color-accent: #c0392b;
  --color-accent-light: #e8c77b;
  --color-accent-muted: rgba(192,57,43,.25);
  --color-bg-dark: #0e0b08;
  --color-text: #ffffff;
  --color-text-muted: rgba(255,255,255,.62);
  --color-text-muted-2: rgba(255,255,255,.35);
  --color-border: rgba(255,255,255,.08);
  --color-border-light: rgba(255,255,255,.06);
  --ff-heading: 'Lora', serif;
  --ff-body: 'Inter', sans-serif;
  --fs-title: clamp(2rem, 7.5vw, 2.9rem);
  --fs-subtitle: 0.9375rem;
  --fs-body: 0.875rem;
  --fs-small: 0.75rem;
  --fs-tiny: 0.68rem;
  --fs-nav: 0.7rem;
  --lh-tight: 1.08;
  --lh-normal: 1.9;
  --nav-height: 4.5rem;
  --container-padding: 1.25rem;
  --radius-sm: 0.125rem;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --duration-fast: 0.2s;
  --duration-medium: 0.35s;
}
@media (min-width: 768px) {
  :root {
    --fs-title: clamp(2.6rem, 4.5vw, 4.2rem);
    --fs-body: 0.9375rem;
    --container-padding: 2rem;
    --nav-height: 5rem;
  }
}
@media (min-width: 1024px) {
  :root {
    --fs-title: clamp(2.1rem, 4vw, 3.7rem);
    --fs-body: 1rem;
    --container-padding: 2.5rem;
    --nav-height: 5.5rem;
  }
}
*,
*::before,
*::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: var(--ff-body); font-size: var(--fs-body); font-weight: 400;
  line-height: var(--lh-normal); color: var(--color-text);
  background: var(--color-bg-dark); overflow-x: hidden;
  -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
}
img { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; }
ul { list-style: none; }
button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
:focus-visible { outline: 2px solid var(--color-accent-light); outline-offset: 2px; }
.icon { width: 1em; height: 1em; fill: none; stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
.icon--md { width: 1.25em; height: 1.25em; }
.icon--fill { fill: currentColor; stroke: none; }
.sr-only { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0,0,0,0); border: 0; }

.hero { position: relative; display: flex; flex-direction: column; overflow: hidden; }
.hero-bg {
  position: absolute; inset: 0;
  background: url('https://images.unsplash.com/photo-1523050854058-8df90110c7f1?w=1600&q=90') center / cover no-repeat;
  animation: zoomin 10s ease-out forwards; will-change: transform;
}
@keyframes zoomin { from { transform: scale(1.06); } to { transform: scale(1); } }
.hero-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(to top, rgba(14,11,8,.98) 0%, rgba(14,11,8,.88) 30%, rgba(14,11,8,.62) 55%, rgba(14,11,8,.28) 75%, rgba(14,11,8,.06) 92%, transparent 100%),
    linear-gradient(to right, rgba(14,11,8,.55) 0%, transparent 60%);
}

.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; height: var(--nav-height); padding-inline: var(--container-padding); transition: background var(--duration-medium) var(--ease-out), box-shadow var(--duration-medium) var(--ease-out); }
.nav--scrolled { background: rgba(14,11,8,.97); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); box-shadow: 0 1px 0 var(--color-border); }
.nav-logo-group { display: flex; align-items: center; gap: .75rem; }
.nav-logo-img { height: 38px; max-width: 160px; width: auto; object-fit: contain; filter: brightness(0) invert(1); display: none; }
.nav-logo-text { font-family: var(--ff-heading); font-size: 1.2rem; font-weight: 700; color: var(--color-text); letter-spacing: .02em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
.nav-logo-text span { color: var(--color-accent-light); }
.nav-list { display: none; }
.nav-list a { font-size: var(--fs-nav); font-weight: 400; letter-spacing: .16em; text-transform: uppercase; color: rgba(255,255,255,.55); transition: color var(--duration-fast); }
.nav-list a:hover, .nav-list a[aria-current] { color: var(--color-accent-light); }
.nav-cta { display: none; align-items: center; gap: .5rem; padding: .6rem 1.5rem; background: var(--color-accent); color: var(--color-text); font-size: var(--fs-nav); font-weight: 600; letter-spacing: .12em; text-transform: uppercase; border-radius: 3px; transition: background var(--duration-fast), color var(--duration-fast); white-space: nowrap; }
.nav-cta:hover { background: var(--color-accent-light); color: var(--color-bg-dark); }

.hamburger { position: relative; z-index: 110; display: flex; flex-direction: column; justify-content: space-between; width: 1.5rem; height: 1rem; padding: 0; }
.hamburger-line { display: block; width: 100%; height: 1.5px; background: var(--color-text); border-radius: 1px; transition: transform var(--duration-medium) var(--ease-out), opacity var(--duration-medium) var(--ease-out); transform-origin: center; }
.hamburger--active .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger--active .hamburger-line:nth-child(2) { opacity: 0; }
.hamburger--active .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
.mobile-menu {
  position: fixed; inset: 0; z-index: 105; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 2rem;
  background: rgba(14,11,8,.98); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  opacity: 0; visibility: hidden; transition: opacity var(--duration-medium) var(--ease-out), visibility var(--duration-medium) var(--ease-out);
}
.mobile-menu--open { opacity: 1; visibility: visible; }
.mobile-menu-close { position: absolute; top: 1rem; right: 1rem; width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center; z-index: 115; }
.mobile-menu-close svg { width: 1.25rem; height: 1.25rem; stroke: var(--color-text); stroke-width: 2; }
.mobile-menu-list { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
.mobile-menu-list a { font-size: var(--fs-nav); font-weight: 400; letter-spacing: .16em; text-transform: uppercase; color: rgba(255,255,255,.6); transition: color var(--duration-fast); }
.mobile-menu-list a:hover { color: var(--color-accent-light); }
.mobile-menu-cta { display: inline-flex; align-items: center; gap: .5rem; padding: .75rem 2rem; background: var(--color-accent); color: var(--color-text); font-size: var(--fs-nav); font-weight: 600; letter-spacing: .12em; text-transform: uppercase; border-radius: 3px; transition: background var(--duration-fast), color var(--duration-fast); }
.mobile-menu-cta:hover { background: var(--color-accent-light); color: var(--color-bg-dark); }
.mobile-menu-tel { display: inline-flex; align-items: center; gap: .5rem; font-size: var(--fs-body); font-weight: 300; color: var(--color-text-muted); transition: color var(--duration-fast); }
.mobile-menu-tel:hover { color: var(--color-text); }
.mobile-menu-divider { width: 2rem; height: 1px; background: var(--color-border); }
body:has(.mobile-menu--open) { overflow: hidden; }

.hero-content { position: relative; z-index: 5; padding: 8rem var(--container-padding) 2rem; max-width: 720px; }
.hero-kicker { display: inline-flex; align-items: center; gap: .625rem; margin-bottom: 1.5rem; }
.hero-kicker svg { width: 1.1rem; height: 1.1rem; color: var(--color-accent-light); stroke-width: 1.8; }
.hero-kicker span { font-size: var(--fs-tiny); font-weight: 600; letter-spacing: .2em; text-transform: uppercase; color: rgba(255,255,255,.55); }

.hero-title {
  font-family: var(--ff-heading); font-size: var(--fs-title);
  font-weight: 700; line-height: var(--lh-tight);
  color: var(--color-text); margin-bottom: 1.25rem;
  text-shadow: 0 2px 24px rgba(0,0,0,.5);
}
.hero-title em { font-style: italic; font-weight: 400; color: var(--color-accent-light); display: block; }
.hero-desc {
  font-size: var(--fs-subtitle); font-weight: 300;
  color: var(--color-text-muted); line-height: var(--lh-normal);
  max-width: 520px; margin-bottom: 1.5rem;
  text-shadow: 0 1px 8px rgba(0,0,0,.5);
}
.hero-features { display: flex; flex-direction: column; gap: .625rem; margin-bottom: 1.75rem; }
.hf-item { display: flex; align-items: center; gap: .75rem; font-size: .8rem; color: rgba(255,255,255,.65); }
.hf-item svg { width: .8rem; height: .8rem; stroke: var(--color-accent-light); stroke-width: 2.5; flex-shrink: 0; }
.hero-ctas { display: flex; flex-direction: column; align-items: flex-start; gap: .75rem; }

.btn-primary {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .875rem 2.25rem; background: var(--color-accent); color: var(--color-text);
  font-size: .75rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
  border-radius: 3px; box-shadow: 0 4px 20px rgba(192,57,43,.4);
  transition: background var(--duration-fast), color var(--duration-fast), transform var(--duration-fast), box-shadow var(--duration-fast); min-height: 3rem;
}
.btn-primary:hover { background: var(--color-accent-light); color: var(--color-bg-dark); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,.3); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: .5rem;
  font-size: .85rem; font-weight: 300; color: rgba(255,255,255,.75);
  padding: .5rem 0; transition: color var(--duration-fast); min-height: 3rem;
}
.btn-ghost-underline { border-bottom: 1px solid rgba(255,255,255,.25); padding-bottom: 1px; transition: border-color var(--duration-fast); }
.btn-ghost:hover { color: var(--color-text); }
.btn-ghost:hover .btn-ghost-underline { border-color: var(--color-text); }

.hero-stats { display: none; }
.hero-scroll { display: none; }

@media (min-width: 768px) {
  .nav-list { display: flex; gap: 2.25rem; }
  .nav-cta { display: inline-flex; }
  .hamburger { display: none; }
  .mobile-menu-close { display: none; }
  .hero-content { padding-top: 10rem; padding-bottom: 3rem; }
  .hero-features { flex-direction: row; gap: 1.5rem; }
  .hero-ctas { flex-direction: row; align-items: center; }
  .btn-primary { padding: .75rem 2rem; min-height: 2.75rem; }
  .btn-ghost { min-height: 2.75rem; }
  
  
}
@media (min-width: 1024px) {
  .hero { min-height: 100svh; }
  .hero-content { padding-bottom: 5rem; }
  .hero-stats {
    display: flex; position: absolute; bottom: 0; right: 0; z-index: 5;
    border-top: 1px solid var(--color-border); border-left: 1px solid var(--color-border);
  }
  .stat-block { padding: 1rem 1.75rem; text-align: center; border-right: 1px solid var(--color-border-light); }
  .stat-block:last-child { border-right: none; }
  .stat-num { font-family: var(--ff-heading); font-size: 1.7rem; font-weight: 600; color: var(--color-text); display: block; line-height: 1; }
  .stat-label { font-size: var(--fs-tiny); font-weight: 400; letter-spacing: .14em; text-transform: uppercase; color: var(--color-text-muted-2); display: block; margin-top: .3rem; }
  .hero-scroll {
    display: flex; position: absolute; bottom: var(--container-padding); left: var(--container-padding); z-index: 5;
    align-items: center; gap: .75rem; color: rgba(255,255,255,.35);
    font-size: var(--fs-tiny); letter-spacing: .2em; text-transform: uppercase;
    writing-mode: vertical-lr; padding-bottom: 1.5rem;
  }
  .hero-scroll::after {
    content: ''; width: 1px; height: 2rem;
    background: linear-gradient(to bottom, rgba(255,255,255,.35), transparent);
    margin-top: .5rem; margin-left: .35rem;
  }
  
  
  
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }
  html { scroll-behavior: auto; }
}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
</head>
<body>

<svg style="display:none" aria-hidden="true">
  <symbol id="icon-phone" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></symbol>
  <symbol id="icon-arrow-right" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></symbol>
  <symbol id="icon-check" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></symbol>
  <symbol id="icon-star" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></symbol>
  <symbol id="icon-graduation" viewBox="0 0 24 24"><path d="M22 10l-10-5L2 10l10 5 10-5z"/><path d="M6 12v5c0 1.66 2.69 3 6 3s6-1.34 6-3v-5"/></symbol>
  <symbol id="icon-book" viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></symbol>
</svg>

<section class="hero" aria-label="Présentation">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>

  <nav class="nav" aria-label="Navigation principale">
    <div class="nav-logo-group">
      <img src="{{LOGO_URL}}" class="nav-logo-img" alt="{{NOM_ENTREPRISE}}" onerror="this.style.display='none'">
      <a href="#" class="nav-logo-text">{{NOM_ENTREPRISE}}<span>.</span></a>
    </div>
    <ul class="nav-list">
      <li><a href="#">Formations</a></li>
      <li><a href="#">Campus</a></li>
      <li><a href="#">Admissions</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
    <a href="tel:{{TELEPHONE}}" class="nav-cta"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>{{TELEPHONE}}</a>
    <button class="hamburger" aria-label="Menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </nav>

  <div class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu de navigation">
    <button class="mobile-menu-close" aria-label="Fermer le menu">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <ul class="mobile-menu-list">
      <li><a href="#">Formations</a></li>
      <li><a href="#">Campus</a></li>
      <li><a href="#">Admissions</a></li>
      <li><a href="#">Contact</a></li>
      <li><a href="#" class="mobile-menu-cta"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>Appeler</a></li>
    </ul>
    <div class="mobile-menu-divider" aria-hidden="true"></div>
    <a href="tel:{{TELEPHONE}}" class="mobile-menu-tel"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>{{TELEPHONE}}</a>
  </div>

  <div class="hero-content">
    <div class="hero-kicker">
      <svg aria-hidden="true"><use href="#icon-graduation"/></svg>
      <span>{{VILLE}} · Ã‰tablissement d'enseignement supérieur</span>
    </div>
    <h1 class="hero-title">
      Bâtissez l'avenir <em>qui vous ressemble</em> avec {{NOM_ENTREPRISE}}
    </h1>
    <p class="hero-desc">
      {{NOM_ENTREPRISE}} forme les talents de demain dans un cadre d'excellence académique à {{VILLE}}.
    </p>
    <div class="hero-features">
      <div class="hf-item"><svg aria-hidden="true"><use href="#icon-check"/></svg><span>Diplômes reconnus</span></div>
      <div class="hf-item"><svg aria-hidden="true"><use href="#icon-check"/></svg><span>Encadrement personnalisé</span></div>
      <div class="hf-item"><svg aria-hidden="true"><use href="#icon-check"/></svg><span>Débouchés garantis</span></div>
    </div>
    <div class="hero-ctas">
      <a href="#" class="btn-primary">Préinscription<svg class="icon icon--md" aria-hidden="true"><use href="#icon-arrow-right"/></svg></a>
      <a href="tel:{{TELEPHONE}}" class="btn-ghost"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg><span class="btn-ghost-underline">{{TELEPHONE}}</span></a>
    </div>
  </div>

  <div class="hero-stats">
    <div class="stat-block"><span class="stat-num">{{NB_ELEVES}}+</span><span class="stat-label">Ã‰tudiants</span></div>
    <div class="stat-block"><span class="stat-num">95%</span><span class="stat-label">Réussite</span></div>
    <div class="stat-block"><span class="stat-num">{{NB_FORMATIONS}}</span><span class="stat-label">Formations</span></div>
  </div>

  <div class="hero-scroll" aria-hidden="true">Découvrir</div>
</section>

<script>(function(){var h=document.querySelector('.hamburger'),m=document.querySelector('.mobile-menu'),n=document.querySelector('.nav');if(!h||!m)return;function t(o){var c=o!==undefined?o:!m.classList.contains('mobile-menu--open');h.classList.toggle('hamburger--active',c);m.classList.toggle('mobile-menu--open',c);h.setAttribute('aria-expanded',c);m.setAttribute('aria-hidden',!c)}h.addEventListener('click',function(){t()});var c=m.querySelector('.mobile-menu-close');if(c)c.addEventListener('click',function(){t(false)});m.querySelectorAll('a').forEach(function(l){l.addEventListener('click',function(){t(false)})});document.addEventListener('keydown',function(e){if(e.key==='Escape'&&m.classList.contains('mobile-menu--open')){t(false);h.focus()}});var mql=window.matchMedia('(min-width: 768px)');mql.addEventListener('change',function(e){if(e.matches&&m.classList.contains('mobile-menu--open'))t(false)});if(n){var s=function(){n.classList.toggle('nav--scrolled',window.scrollY>60)};window.addEventListener('scroll',s,{passive:true});s()}})();</script>
<script>
(function(){var m=window.matchMedia('(prefers-reduced-motion:reduce)');if(m.matches)return;gsap.registerPlugin(ScrollTrigger);var b=document.querySelector('.hero-bg');if(b){gsap.fromTo(b,{scale:1.08},{scale:1,duration:1.5,ease:'power2.out'})}var h=document.querySelector('.hero-content,.hero-inner,.hero-body');if(h){var c=[];for(var i=0;i<h.children.length;i++){c.push(h.children[i])}gsap.fromTo(c,{y:36,opacity:0},{y:0,opacity:1,duration:.65,stagger:.1,ease:'power2.out',delay:.15})}var s=document.querySelectorAll('.hero-stat-num,.stat-num');s.forEach(function(e){var t=e.textContent.trim();if(/^\d+$/.test(t)){var n=parseInt(t,10);if(n>0&&!isNaN(n)){var o={val:0};gsap.to(o,{val:n,duration:2,ease:'power2.out',scrollTrigger:{trigger:e.closest('.hero-stats,.hero-stats-row')||e.parentElement,start:'top 90%',once:true},onUpdate:function(){e.textContent=Math.round(o.val)}})}}})})();
</script>
</body>
</html>
