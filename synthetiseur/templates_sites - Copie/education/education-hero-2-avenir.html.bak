<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{NOM_ENTREPRISE}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --color-accent: #06b6d4;
  --color-accent-light: #22d3ee;
  --color-accent-muted: rgba(6,182,212,.2);
  --color-bg-dark: #0b1215;
  --color-text: #ffffff;
  --color-text-muted: rgba(255,255,255,.65);
  --color-text-muted-2: rgba(255,255,255,.4);
  --color-border: rgba(255,255,255,.1);
  --color-border-light: rgba(255,255,255,.06);
  --color-glass-bg: rgba(11,18,21,.72);
  --ff-heading: 'DM Sans', sans-serif;
  --ff-body: 'Inter', sans-serif;
  --fs-title: clamp(1.8rem, 7vw, 2.5rem);
  --fs-subtitle: clamp(.875rem, 2.5vw, .9375rem);
  --fs-body: .875rem;
  --fs-small: .75rem;
  --fs-tiny: .65rem;
  --fs-nav: .7rem;
  --lh-tight: 1.05;
  --lh-normal: 1.7;
  --nav-height: 4.25rem;
  --container-padding: 1.25rem;
  --radius-sm: 3px;
  --radius-md: 6px;
  --radius-full: 9999px;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --duration-fast: .2s;
  --duration-medium: .35s;
}
@media (min-width: 768px) {
  :root {
    --fs-title: clamp(2.2rem, 4.5vw, 3.2rem);
    --fs-body: .9375rem;
    --container-padding: 2rem;
    --nav-height: 5rem;
  }
}
@media (min-width: 1024px) {
  :root {
    --fs-body: 1rem;
    --fs-tiny: .7rem;
    --container-padding: 2.5rem;
    --nav-height: 5.5rem;
  }
}
*,
*::before,
*::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: var(--ff-body); font-size: var(--fs-body); font-weight: 400;
  line-height: var(--lh-normal); color: var(--color-text);
  background: var(--color-bg-dark); overflow-x: hidden;
  -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
}
img { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; }
button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
.icon { width: 1em; height: 1em; fill: none; stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
.icon--md { width: 1.25em; height: 1.25em; }
.sr-only { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0,0,0,0); border: 0; }

.nav-wrapper {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  transition: background var(--duration-medium) var(--ease-out), border-color var(--duration-medium) var(--ease-out), backdrop-filter var(--duration-medium) var(--ease-out);
  border-bottom: 1px solid transparent;
}
.nav-wrapper--scrolled {
  background: var(--color-glass-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom-color: var(--color-border);
}
.nav {
  display: flex; align-items: center; justify-content: space-between;
  height: var(--nav-height); padding-inline: var(--container-padding); max-width: 1280px; margin-inline: auto;
}
.nav-logo {
  font-family: var(--ff-heading); font-size: 1.2rem; font-weight: 700;
  color: var(--color-text); letter-spacing: -.02em; white-space: nowrap; line-height: 1;
}
.nav-logo span { color: var(--color-accent); }
.nav-desktop { display: none; align-items: center; gap: 2.5rem; }
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a {
  font-size: var(--fs-nav); font-weight: 500; letter-spacing: .14em; text-transform: uppercase;
  color: var(--color-text-muted); transition: color var(--duration-fast); position: relative;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0; right: 0; height: 1.5px;
  background: var(--color-accent); transform: scaleX(0); transition: transform var(--duration-fast) var(--ease-out);
}
.nav-links a:hover { color: var(--color-text); }
.nav-links a:hover::after { transform: scaleX(1); }
.nav-cta {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .55rem 1.4rem; background: var(--color-accent); color: var(--color-text);
  font-size: var(--fs-nav); font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
  border-radius: var(--radius-sm); transition: background var(--duration-fast), color var(--duration-fast), transform var(--duration-fast); white-space: nowrap;
}
.nav-cta:hover { background: var(--color-accent-light); color: var(--color-bg-dark); transform: translateY(-1px); }
.nav-mobile { display: flex; align-items: center; justify-content: space-between; width: 100%; gap: .75rem; }

.hamburger {
  position: relative; z-index: 110; display: flex; flex-direction: column; justify-content: space-between;
  width: 1.5rem; height: 1rem; padding: 0; flex-shrink: 0;
}
.hamburger-line {
  display: block; width: 100%; height: 1.5px; background: var(--color-text);
  border-radius: 1px; transition: transform var(--duration-medium) var(--ease-out), opacity var(--duration-medium) var(--ease-out);
  transform-origin: center;
}
.hamburger--active .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger--active .hamburger-line:nth-child(2) { opacity: 0; }
.hamburger--active .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.mobile-menu {
  position: fixed; inset: 0; z-index: 105; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 2rem;
  background: rgba(11,18,21,.97); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  opacity: 0; visibility: hidden; transition: opacity var(--duration-medium) var(--ease-out), visibility var(--duration-medium) var(--ease-out);
}
.mobile-menu--open { opacity: 1; visibility: visible; }
.mobile-menu-close {
  position: absolute; top: 1rem; right: 1rem; width: 2.5rem; height: 2.5rem;
  display: flex; align-items: center; justify-content: center; z-index: 115;
}
.mobile-menu-close svg { width: 1.25rem; height: 1.25rem; stroke: var(--color-text); stroke-width: 2; }
.mobile-menu-list { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; list-style: none; }
.mobile-menu-list a {
  font-size: .85rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
  color: rgba(255,255,255,.75); transition: color var(--duration-fast);
}
.mobile-menu-list a:hover { color: var(--color-text); }
.mobile-menu-cta {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .75rem 2rem; border: 1px solid rgba(255,255,255,.25); border-radius: var(--radius-sm);
  font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.75);
  transition: background var(--duration-fast), border-color var(--duration-fast);
}
.mobile-menu-cta:hover { background: var(--color-accent); border-color: var(--color-accent); color: var(--color-text); }
body:has(.mobile-menu--open) { overflow: hidden; }

.hero {
  position: relative; min-height: 100svh; display: flex; flex-direction: column; overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background: url('https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=1600&q=85') center / cover no-repeat;
  will-change: transform;
}
.hero-bg::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(11,18,21,.52) 0%, rgba(11,18,21,.82) 100%);
}
.hero-inner {
  position: relative; z-index: 1; flex: 1; display: flex; flex-direction: column;
  padding: calc(var(--nav-height) + 2rem) var(--container-padding) 2rem;
  max-width: 1280px; margin-inline: auto; width: 100%;
}
.hero-content {
  flex: 1; display: flex; flex-direction: column; justify-content: center;
  max-width: 680px; padding: 1rem 0;
}
.hero-kicker {
  display: inline-flex; align-items: center; gap: .5rem; margin-bottom: 1.5rem;
  padding: .35rem 1rem .35rem .35rem; border-radius: var(--radius-full);
  background: rgba(255,255,255,.06); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.08);
}
.kicker-dot {
  width: 1.75rem; height: 1.75rem; border-radius: 50%; background: var(--color-accent-muted);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.kicker-dot svg { width: .75rem; height: .75rem; stroke: var(--color-accent); stroke-width: 2.5; fill: var(--color-accent); }
.kicker-text {
  font-size: var(--fs-tiny); font-weight: 600; letter-spacing: .15em; text-transform: uppercase;
  color: var(--color-text-muted); padding-right: .25rem;
}
.hero-title {
  font-family: var(--ff-heading); font-size: var(--fs-title); font-weight: 700;
  line-height: var(--lh-tight); color: var(--color-text); margin-bottom: 1.25rem;
  text-shadow: 0 2px 20px rgba(0,0,0,.35);
}
.hero-title em { font-weight: 400; font-style: italic; color: var(--color-accent-light); }
.hero-desc {
  font-size: var(--fs-subtitle); font-weight: 300; color: var(--color-text-muted);
  line-height: 1.8; max-width: 480px; margin-bottom: 2rem;
  text-shadow: 0 1px 12px rgba(0,0,0,.3);
}
.hero-ctas { display: flex; flex-direction: column; gap: .75rem; align-items: flex-start; }
.btn-primary {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .875rem 2rem; background: var(--color-accent); color: var(--color-text);
  font-size: .74rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
  border-radius: var(--radius-sm); box-shadow: 0 4px 20px rgba(6,182,212,.3);
  transition: background var(--duration-fast), color var(--duration-fast), transform var(--duration-fast), box-shadow var(--duration-fast); min-height: 3rem;
}
.btn-primary:hover { background: var(--color-accent-light); color: var(--color-bg-dark); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,.35); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .875rem 1.5rem; border: 1.5px solid rgba(255,255,255,.2);
  color: rgba(255,255,255,.75); font-size: .74rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
  border-radius: var(--radius-sm); transition: border-color var(--duration-fast), color var(--duration-fast); min-height: 3rem;
}
.btn-ghost:hover { border-color: var(--color-text); color: var(--color-text); }

.hero-stats { display: none; }

.hero-scroll { display: none; }

@media (min-width: 768px) {
  .nav-desktop { display: flex; }
  .nav-mobile { display: none; }
  .hero-inner { padding-top: calc(var(--nav-height) + 3rem); padding-bottom: 3rem; }
  .hero-content { max-width: 620px; }
  .hero-ctas { flex-direction: row; align-items: center; }
  .btn-primary { padding: .75rem 2rem; min-height: 2.75rem; }
  .btn-ghost { min-height: 2.75rem; }
  
  
}

@media (min-width: 1024px) {
  .hero-inner { padding-top: calc(var(--nav-height) + 3rem); padding-bottom: 0; }
  .hero-content { max-width: 680px; padding-bottom: 6rem; }
  .hero-scroll {
    display: flex; position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 2;
    flex-direction: column; align-items: center; gap: .5rem;
    color: rgba(255,255,255,.45); animation: scrollBounce 2.5s ease-in-out infinite;
  }
  .hero-scroll span { font-size: var(--fs-tiny); font-weight: 500; letter-spacing: .15em; text-transform: uppercase; }
  .hero-scroll svg { width: 1rem; height: 1rem; stroke: currentColor; stroke-width: 1.5; }
  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }
  .hero-stats {
    display: flex; align-items: center; justify-content: center; gap: 3rem;
    padding: 1.5rem 0; position: relative; z-index: 2;
    border-top: 1px solid rgba(255,255,255,.08);
  }
  .hero-stat { text-align: center; }
  .hero-stat-num {
    font-family: var(--ff-heading); font-size: 1.6rem; font-weight: 700; color: var(--color-text);
    display: block; line-height: 1.1; letter-spacing: -.02em;
  }
  .hero-stat-num span { color: var(--color-accent-light); }
  .hero-stat-label {
    font-size: var(--fs-small); font-weight: 400; color: var(--color-text-muted-2);
    display: block; margin-top: .2rem; letter-spacing: .02em;
  }
  .hero-stat-divider { width: 1px; height: 2.5rem; background: rgba(255,255,255,.08); flex-shrink: 0; }
  
  
  
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }
  html { scroll-behavior: auto; }
}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
</head>
<body>

<svg style="display:none" aria-hidden="true">
  <symbol id="icon-phone" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></symbol>
  <symbol id="icon-arrow-right" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></symbol>
  <symbol id="icon-star" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></symbol>
  <symbol id="icon-check" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></symbol>
</svg>

<div class="nav-wrapper" role="banner">
  <nav class="nav" aria-label="Navigation principale">
    <a href="#" class="nav-logo">{{NOM_ENTREPRISE}}<span>.</span></a>
    <div class="nav-desktop">
      <ul class="nav-links">
        <li><a href="#">Formations</a></li>
        <li><a href="#">Campus</a></li>
        <li><a href="#">Admissions</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
      <a href="tel:{{TELEPHONE}}" class="nav-cta"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>Appeler</a>
    </div>
    <div class="nav-mobile">
      <a href="#" class="nav-logo">{{NOM_ENTREPRISE}}<span>.</span></a>
      <button class="hamburger" aria-label="Menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </nav>
</div>

<div class="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu de navigation">
  <button class="mobile-menu-close" aria-label="Fermer le menu">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <ul class="mobile-menu-list">
    <li><a href="#">Formations</a></li>
    <li><a href="#">Campus</a></li>
    <li><a href="#">Admissions</a></li>
    <li><a href="#">Contact</a></li>
    <li><a href="#" class="mobile-menu-cta"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>Appeler</a></li>
  </ul>
</div>

<section class="hero" aria-label="Présentation">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-kicker">
        <div class="kicker-dot"><svg aria-hidden="true"><use href="#icon-star"/></svg></div>
        <span class="kicker-text">Formation · {{VILLE}}</span>
      </div>
      <h1 class="hero-title">Des formations <em>d'excellence</em> pour construire votre avenir</h1>
      <p class="hero-desc">Rejoignez {{NOM_ENTREPRISE}} à {{VILLE}} — un enseignement d'excellence reconnu par les plus grandes entreprises.</p>
      <div class="hero-ctas">
        <a href="#" class="btn-primary">S'inscrire<svg class="icon icon--md" aria-hidden="true"><use href="#icon-arrow-right"/></svg></a>
        <a href="tel:{{TELEPHONE}}" class="btn-ghost"><svg class="icon" aria-hidden="true"><use href="#icon-phone"/></svg>{{TELEPHONE}}</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-num">{{NB_ELEVES}}<span>+</span></span>
        <span class="hero-stat-label">Ã‰tudiants</span>
      </div>
      <div class="hero-stat-divider" aria-hidden="true"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">95<span>%</span></span>
        <span class="hero-stat-label">Réussite</span>
      </div>
      <div class="hero-stat-divider" aria-hidden="true"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">{{NB_FORMATIONS}}</span>
        <span class="hero-stat-label">Formations</span>
      </div>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span>Découvrir</span>
    <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
  </div>
</section>

<script>(function(){var h=document.querySelector('.hamburger'),m=document.querySelector('.mobile-menu');if(!h||!m)return;function t(o){var n=o!==undefined?o:!m.classList.contains('mobile-menu--open');h.classList.toggle('hamburger--active',n);m.classList.toggle('mobile-menu--open',n);h.setAttribute('aria-expanded',n);m.setAttribute('aria-hidden',!n)}h.addEventListener('click',function(){t()});var c=m.querySelector('.mobile-menu-close');if(c)c.addEventListener('click',function(){t(false)});m.querySelectorAll('a').forEach(function(l){l.addEventListener('click',function(){t(false)})});document.addEventListener('keydown',function(e){if(e.key==='Escape'&&m.classList.contains('mobile-menu--open')){t(false);h.focus()}});var mql=window.matchMedia('(min-width: 768px)');mql.addEventListener('change',function(e){if(e.matches&&m.classList.contains('mobile-menu--open'))t(false)})})();</script>
<script>
(function(){var m=window.matchMedia('(prefers-reduced-motion:reduce)');if(m.matches)return;
var nw=document.querySelector('.nav-wrapper');if(nw){function u(){nw.classList.toggle('nav-wrapper--scrolled',window.scrollY>50)}window.addEventListener('scroll',u,{passive:true});u()}
gsap.registerPlugin(ScrollTrigger);var b=document.querySelector('.hero-bg');if(b){gsap.fromTo(b,{scale:1.06},{scale:1,duration:1.5,ease:'power2.out'})}var c=document.querySelector('.hero-content');if(c){var ch=[];for(var i=0;i<c.children.length;i++){ch.push(c.children[i])}gsap.fromTo(ch,{y:36,opacity:0},{y:0,opacity:1,duration:.65,stagger:.1,ease:'power2.out',delay:.15})}var sn=document.querySelectorAll('.hero-stat-num');sn.forEach(function(e){var t=e.textContent.trim().replace(/[+\-%]/g,'');if(/^\d+$/.test(t)){var n=parseInt(t,10);if(n>0&&!isNaN(n)){var o={val:0};gsap.to(o,{val:n,duration:2,ease:'power2.out',scrollTrigger:{trigger:e.closest('.hero-stats'),start:'top 90%',once:true},onUpdate:function(){var sfx=e.textContent.includes('%')?'%':e.textContent.includes('+')?'+':'';e.textContent=Math.round(o.val)+sfx}})}}})})();
</script>
</body>
</html>
